{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C gcc build driver and dependencies",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "driver.c",
                "parser.c",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Manually made task"
        }
    ],
    "version": "2.0.0"
}